#include <iostream>
#include <cmath>
using namespace std;

int main() {
    double radius, volume;
    const double PI = 3.14159;

    cout << "Enter the radius of the sphere: ";
    cin >> radius;

    // Volume = (4/3) * PI * r^3
    volume = (4.0 / 3.0) * PI * pow(radius, 3);
    cout << "The volume of the sphere is: " << volume << endl;

    return 0;
}
